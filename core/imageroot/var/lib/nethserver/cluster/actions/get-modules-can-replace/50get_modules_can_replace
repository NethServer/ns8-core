import agent
import sys
import json
import cluster.modules

# Write privileges are required for Redis repository metadata caching:
rdb = agent.redis_connect(privileged=True)
available = cluster.modules.list_available(rdb, skip_core_modules=False)

can_replace = {}
for omod in available:
    try:
        image_name = omod["source"].rsplit("/", 1)[-1]
    except (KeyError, IndexError):
        continue
    try:
        max_per_node = int(omod["versions"][0]["labels"]["org.nethserver.max-per-node"])
    except (KeyError, IndexError, ValueError):
        max_per_node = 9999
    try:
        flags = omod["versions"][0]["labels"].get("org.nethserver.flags", "").split()
    except (KeyError, IndexError, AttributeError):
        flags = []
    # A module cannot replace an existing instance if:
    # - org.nethserver.max-per-node=1: only one instance is allowed per node
    #   (e.g. samba, mail, ejabberd, nethvoice-proxy). A replace would require
    #   spinning up a second temporary instance on the same node, which is
    #   forbidden by this constraint.
    # - org.nethserver.flags contains "core_module" but NOT "account_provider":
    #   pure infrastructure singletons (e.g. loki, traefik) are managed by the
    #   node itself and must always be running. Account-provider core modules
    #   (e.g. openldap) carry both flags and ARE replaceable.
    is_infra_singleton = "core_module" in flags and "account_provider" not in flags
    can_replace[image_name] = max_per_node != 1 and not is_infra_singleton

json.dump({"can_replace": can_replace}, fp=sys.stdout)
