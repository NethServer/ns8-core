{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "get-modules-can-replace output",
    "$id": "http://schema.nethserver.org/cluster/get-modules-can-replace-output.json",
    "description": "Output schema of the get-modules-can-replace action",
    "examples": [
        {
            "can_replace": {
                "samba": false,
                "loki": false,
                "mail": false,
                "ejabberd": false,
                "nethvoice-proxy": false,
                "dokuwiki": true
            }
        }
    ],
    "type": "object",
    "required": ["can_replace"],
    "properties": {
        "can_replace": {
            "type": "object",
            "description": "Map of module image name to boolean: true if a restore-over-replace is allowed for that module, false if not (e.g. max-per-node=1 or core_module flag)",
            "additionalProperties": {
                "type": "boolean"
            }
        }
    }
}
