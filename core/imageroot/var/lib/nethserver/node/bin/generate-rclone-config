import agent
import sys
import os
import argparse
import cluster.backup
import configparser
import agent.backup
import time


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--rclonedir", required=False, help="Write rclone configuration file to given directory")
    parser.add_argument("--haproxydir", required=False, help="Write HAProxy configuration files to given directory")
    parser.add_argument("--retry", metavar="TIMES", required=False, type=int, default=0, help="Check if WebDAV service is up")
    args = parser.parse_args()
    rdb = agent.redis_connect(privileged=True, use_replica=True)
    if args.rclonedir:
        rclone_conf = args.rclonedir + '/rclone.conf'
        if args.retry:
            retry_webdav_startup(rclone_conf, args.retry)
        else:
            with agent.safe_open(rclone_conf, "w") as fd:
                write_rclonecfg(fd, rdb)
    if args.haproxydir:
        with agent.safe_open(args.haproxydir + "/config.env", "w") as fd:
            write_config_env(fd, rdb)
        with agent.safe_open(args.haproxydir  + '/auth.map', "w") as fd:
            write_auth_map(fd, rdb)
        with agent.safe_open(args.haproxydir + "/modrepo.map", "w") as fd:
            write_modrepomap(fd, rdb)
    if not args.rclonedir and not args.haproxydir:
        parser.error("No argument found")

def retry_webdav_startup(rclone_conf, attempts):
    rc = configparser.ConfigParser()
    rc.read_file(open(rclone_conf), rclone_conf)
    try:
        dest_uuid = rc.sections()[0]
    except IndexError:
        sys.exit(0)
    check_url = f"http://127.0.0.1:4694/{dest_uuid}/"
    with agent.backup.TimeoutSession(timeout=(3, 10)) as rses:
        for attempt in range(1, attempts):
            req = rses.head(check_url)
            if req.status_code == 200:
                break
            time.sleep(1)
        else:
            print("[ERROR] Retry attempts exhausted!", file=sys.stderr)
            sys.exit(3)

def write_config_env(fileo, rdb):
    cluster_network = rdb.get("cluster/network") or "0.0.0.0/32"
    print("CLUSTER_NETWORK=" + cluster_network, file=fileo)

def write_auth_map(fileo, rdb):
    try:
        redis_acl_list = rdb.smembers('cluster/acls')
    except Exception as ex:
        print(ex, file=sys.stderr)
        redis_acl_list = set()
    for acl_entry in redis_acl_list:
        acl_fields = acl_entry.split()
        user = acl_fields[1]
        if user.startswith('node/'):
            group = "nodes"
        elif user.startswith('module/'):
            group = "modules"
        else:
            continue # skip
        secret = next(filter(lambda x: x.startswith("#"), acl_fields))
        secret = secret.lstrip("#").lower()
        if user and secret:
            creds = user + ':' + secret
            print(f"{creds:<88} {group}", file=fileo)

def write_modrepomap(fileo, rdb):
    try:
        module_uuid_map = rdb.hgetall('cluster/module_uuid')
    except Exception:
        module_uuid_map = dict()
    try:
        restore_map = rdb.hgetall('private/nodes/restore_uuid')
    except Exception:
        restore_map = dict()
    for mid, muuid in module_uuid_map.items():
        # Strip trailing digits to derive the app type
        app_type = mid.rstrip("0123456789")
        repopath = f"{app_type}/{muuid}"
        print(f"module/{mid:<16} {repopath}", file=fileo)
        if muuid in restore_map:
            # Enable access to source app's repository for restoration
            source_uuid = restore_map[muuid]
            print(f"    {repopath} {app_type}/{source_uuid}", file=fileo)

def write_rclonecfg(fileo, rdb):
    destinations = []
    print(";\n; generated automatically from Redis DB contents\n;\n", file=fileo)
    try:
        rclone_conf_map = rdb.hgetall('private/nodes/backup_destination/rclone_conf')
        node_vpn_ip = rdb.hget(f"node/{os.environ['NODE_ID']}/vpn", "ip_address")
        node_url = f"webdav:http://{node_vpn_ip}:4694"
    except Exception as ex:
        rclone_conf_map = dict()
    for key, conf in rclone_conf_map.items():
        conf = conf.strip() + "\n"
        if conf:
            try:
                backup_conf = rdb.hgetall('cluster/backup_repository/' + key)
                if backup_conf['provider'] == 'rclone':
                    destination_basepath = backup_conf['basepath']
                else:
                    destination_basepath = cluster.backup.extract_rclone_basepath(backup_conf['url'])
            except Exception as ex:
                print(agent.SD_WARNING + f"Backup destination {key} config parse failed:", ex, file=sys.stderr)
                continue
            # Override configuration for the local node repository:
            if backup_conf['provider'] == 'cluster':
                if backup_conf['url'] == node_url:
                    conf = f"[{key}]\ntype = local\n"
                    destination_basepath = "/srv/repo"
                else:
                    continue
            destinations.append(f"{key}={key}:{destination_basepath.rstrip('/')}")
            print(conf, file=fileo)
    # The "combined" remote merges all other destinations in a unique
    # logical tree, where root-level elements correspond to destination
    # UUIDs.
    if destinations:
        print((
            "[combined]\n"
            "type = combine\n"
            "upstreams = " + ' '.join(destinations) + "\n"
        ), file=fileo)

if __name__ == '__main__':
    main()
