set -e
exec 1>&2

old_hostname=$(hostname -s)

read -r hostname domain < <(jq -r '[.hostname, .domain] | join("\t")')

# Raise error, if values are empty
: "${hostname:?}" "${domain:?}"

hostnamectl set-hostname "${hostname}"

# For localhost lines (127.0.0.1 or ::1 with a localhost* alias), remove the old
# hostname field; for all other lines containing it, prefix with a comment marker.
# Uses awk field splitting (no regexp) for exact word matching.
awk -v old_host="${old_hostname}" '
# Pass through comment lines and blank lines unchanged
/^[[:space:]]*#/ || /^[[:space:]]*$/ { print; next }
{
    # Check if old_host appears as an exact field in this line
    found = 0
    for (i = 1; i <= NF; i++) {
        if ($i == old_host) { found = 1; break }
    }
    # No match: print unchanged and move on
    if (!found) { print; next }

    # Determine whether this is a localhost line: the IP must be
    # 127.0.0.1 or ::1 AND at least one alias must be localhost*.
    # Such lines must not be commented out entirely.
    is_localhost = 0
    if ($1 == "127.0.0.1" || $1 == "::1") {
        for (i = 2; i <= NF; i++) {
            if ($i == "localhost" || $i == "localhost4" || $i == "localhost6") {
                is_localhost = 1; break
            }
        }
    }

    if (is_localhost) {
        # Rebuild the line omitting the old hostname field
        line = $1
        for (i = 2; i <= NF; i++) {
            if ($i != old_host) line = line " " $i
        }
        print line
    } else {
        # Comment out the whole line so it is no longer active
        print "# commented by set-fqdn #" $0
    }
}
' /etc/hosts > /etc/hosts.$$.tmp && mv /etc/hosts.$$.tmp /etc/hosts

# Append to /etc/hosts according to hostname man page:
printf "127.0.1.1 %s %s\n" "${hostname}.${domain}" "${hostname}" >> /etc/hosts

# write the MOTD and exit
/usr/bin/systemctl start api-server-motd.service
