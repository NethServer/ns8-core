set -e
exec 1>&2

# Stop the tunnel service. The tunnel-client handles user cleanup on
# SIGTERM: it runs teardown on users.d plugins and deletes ephemeral
# users (cluster-admin, domain users) before exiting.
systemctl stop support-tunnel.service 2>/dev/null || true

# Clean up Redis state
source /var/lib/nethserver/node/state/environment
NODE_ID="${NODE_ID:-1}"
redis-cli DEL "node/${NODE_ID}/tunnel" > /dev/null
