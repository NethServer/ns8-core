# shellcheck shell=dash

echo "Restarting backends..."
rclone-serve-restart
rclone_rc=$?
echo "Reloading frontend..."
# shellcheck disable=SC2046
[ -f /var/lib/rclone/haproxy.pid ] && kill -HUP $(cat /var/lib/rclone/haproxy.pid)
exit "${rclone_rc}"
